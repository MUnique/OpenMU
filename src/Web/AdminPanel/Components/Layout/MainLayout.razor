@using MUnique.OpenMU.Web.AdminPanel.Properties

@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <header class="main-header navbar navbar-expand navbar-light bg-light border-bottom">
            <div class="container-fluid px-4">
                <div class="header-content d-flex align-items-center w-100">
                    <div class="header-search flex-grow-1">
                        <ConfigurationSearch />
                    </div>
                    <div class="header-actions ml-3">
                        <a href="https://munique.net" target="_blank" class="text-secondary small">@Resources.About</a>
                    </div>
                </div>
            </div>
        </header>

        <div class="breadcrumb-bar bg-white border-bottom px-4 py-1">
            <div class="d-flex align-items-center">
                <BreadcrumbNavigation />
            </div>
        </div>

        <BlazoredToasts />

        <article class="content px-4 py-3">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
  @Resources.UnhandledErrorOccurred
  <a href="." class="reload">@Resources.Reload</a>
  <span class="dismiss">🗙</span>
</div>
