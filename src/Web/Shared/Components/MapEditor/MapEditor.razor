@using MUnique.OpenMU.DataModel
@using MUnique.OpenMU.DataModel.Configuration
@using MUnique.OpenMU.Persistence
@using MUnique.OpenMU.Web.Shared.Properties
@using SixLabors.ImageSharp
@using SixLabors.ImageSharp.Formats.Png
@using System.Globalization

@implements IAsyncDisposable

@if (this._selectedMap is null)
{
    return;
}

<h3>@this.SelectedMap.Name</h3>

<div class="map-select">
    <label for="mapSelect">@Resources.SelectedMap:</label>
    <select title="Map" @onchange=this.OnMapSelectedAsync id="mapSelect" autocomplete="off">
        @foreach (var map in this.Maps ?? Enumerable.Empty<GameMapDefinition>())
        {
            <option value="@map.GetId()" selected=@(object.Equals(this.SelectedMap, map))>@Resources.Map: @map.ToString()</option>
        }
    </select>
</div>

<div class="btn-toolbar my-2" role="toolbar" aria-label="@Resources.Toolbar">
    <div class="btn-group mr-2" role="group" aria-label="@Resources.CreationGroup">
        <button type="button" class="btn btn-secondary" @onclick="@this.CreateNewSpawnArea" disabled="@this._createMode">
            <span class="oi oi-plus"></span> @typeof(MonsterSpawnArea).GetTypeCaption()
        </button>
        <button type="button" class="btn btn-secondary" @onclick="@this.CreateNewEnterGate" disabled="@this._createMode">
            <span class="oi oi-plus"></span> @typeof(EnterGate).GetTypeCaption()
        </button>
        <button type="button" class="btn btn-secondary" @onclick="@this.CreateNewExitGate" disabled="@this._createMode">
            <span class="oi oi-plus"></span> @typeof(ExitGate).GetTypeCaption()
        </button>
    </div>
    <div class="btn-group" role="group" aria-label="@Resources.ControlGroup">
        @if (this._createMode)
        {
            <button id="applyCreate" type="button" class="btn btn-primary" @onclick="@(_ => this._createMode = false)">
                <span class="oi oi-circle-check"></span>
            </button>
            <button id="cancelCreate" type="button" class="btn btn-secondary" @onclick="@this.CancelCreation">
                <span class="oi oi-circle-x"></span>
            </button>
        }
        else
        {
            <button type="button"
                    class="btn btn-secondary"
                    @onclick="@this.UndoLastAction"
                    disabled="@(!this._history.CanUndo)"
                    title="@Resources.Undo">
                <span class="oi oi-action-undo"></span> @Resources.Undo
            </button>
            @if (this._focusedObject is not null)
            {
                <button id="duplicateFocused" type="button" class="btn btn-secondary" @onclick="@this.DuplicateFocusedObject">
                    <span class="oi oi-layers"></span> @Resources.Duplicate
                </button>
                <button id="removeFocused" type="button" class="btn btn-secondary" @onclick="@this.RemoveFocusedObject">
                    <span class="oi oi-x"></span> @Resources.Remove
                </button>
            }
            <button type="button"
                    class="btn btn-primary ms-2"
                    @onclick="@this.SaveAsync"
                    title="@Resources.Save">
                <span class="oi oi-cloud-upload"></span> @Resources.Save
            </button>
        }
    </div>
</div>

<div class="map-editor-row">
    <div class="map-column">
        @if (this._terrainImage is { })
        {
            <div class="map-host-container">
                <div class="map-host"
                     @onmousedown="@this.OnMapMouseDownAsync"
                     @onmousemove="@this.OnMouseMoveAsync"
                     @onmouseup="@this.OnMapMouseUp"
                     @onmouseleave="@this.OnMapMouseLeave"
                     @onwheel="@this.OnWheelAsync"
                     @onwheel:preventDefault="true"
                     @onwheel:stopPropagation="true"
                     @ref="_mapHostRef">
                    <div class="map-content">
                        <img src="@(this._terrainImage.ToBase64String(PngFormat.Instance))"
                             draggable="false"
                             alt="@string.Format(Resources.TerrainOf, this.SelectedMap.Name)" />
                        @foreach (var obj in this.GetMapObjects())
                        {
                            <div class="@this.GetCssClass(obj)"
                                 title="@obj.ToString()"
                                 style="@this.GetSizeAndPositionStyle(obj)">
                                @if (this.ShowResizers(obj))
                                {
                                    <Resizers Resizing="@this.OnStartResizing" />
                                }
                                else if (this.ShowArrow(obj, out var spawn))
                                {
                                    <div class="arrow @this.GetFocusedRotation()"></div>
                                }

                                @if (this.GetObjectSize(obj) is { } size)
                                {
                                    <span class="object-size-label">@size</span>
                                }
                            </div>
                        }

                        @if (this._showGrid)
                        {
                            <div class="coordinate-grid" style="@this.GetGridStyle()"></div>
                        }
                    </div>
                </div>

                <div class="map-coordinates-overlay">
                    <span class="coord-label">X: @this._mouseMapX, Y: @this._mouseMapY</span>
                </div>

                <div class="map-zoom-display">
                    <span class="zoom-label">@this.ZoomPercentage%</span>
                </div>
            </div>
        }

        <div class="map-zoom-toolbar btn-toolbar my-2" role="toolbar">
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-secondary"
                        @onclick="@this.ZoomOutAsync"
                        disabled="@(this._zoomManager is null || this._zoomManager.IsAtMinZoom)">
                    <span class="oi oi-minus"></span>
                </button>
                <button type="button" class="btn btn-secondary zoom-display" disabled>
                    @this.ZoomPercentage%
                </button>
                <button type="button" class="btn btn-secondary"
                        @onclick="@this.ZoomInAsync"
                        disabled="@(this._zoomManager is null || this._zoomManager.IsAtMaxZoom)">
                    <span class="oi oi-plus"></span>
                </button>
                <button type="button" class="btn btn-secondary ms-2"
                        @onclick="@this.ResetZoomAsync"
                        title="@Resources.ResetZoom">
                    <span class="oi oi-reload"></span>
                </button>
                <button type="button" class="btn @(this._showGrid ? "btn-primary" : "btn-secondary") ms-1"
                        @onclick="@(() => this._showGrid = !this._showGrid)"
                        title="@Resources.ToggleGrid">
                    <span class="oi oi-grid-three-up"></span>
                </button>
            </div>
        </div>
    </div>

    <div class="map-object-column">
        @if (!this._createMode)
        {
            <div class="map-object-filter mb-2">
                <div class="btn-group w-100 mb-1" role="group" aria-label="@Resources.TypeFilter">
                    <button type="button"
                            class="btn btn-sm @(this._activeFilter == ObjectTypeFilter.All ? "btn-primary" : "btn-outline-primary")"
                            @onclick="@(() => this.SetActiveFilter(ObjectTypeFilter.All))">
                        @Resources.All
                    </button>
                    <button type="button"
                            class="btn btn-sm @(this._activeFilter == ObjectTypeFilter.Monsters ? "btn-primary" : "btn-outline-primary")"
                            @onclick="@(() => this.SetActiveFilter(ObjectTypeFilter.Monsters))">
                        @Resources.Monsters
                    </button>
                    <button type="button"
                            class="btn btn-sm @(this._activeFilter == ObjectTypeFilter.Npcs ? "btn-primary" : "btn-outline-primary")"
                            @onclick="@(() => this.SetActiveFilter(ObjectTypeFilter.Npcs))">
                        @Resources.Npcs
                    </button>
                    <button type="button"
                            class="btn btn-sm @(this._activeFilter == ObjectTypeFilter.Gates ? "btn-primary" : "btn-outline-primary")"
                            @onclick="@(() => this.SetActiveFilter(ObjectTypeFilter.Gates))">
                        @Resources.Gates
                    </button>
                    <button type="button"
                            class="btn btn-sm @(this._activeFilter == ObjectTypeFilter.Others ? "btn-primary" : "btn-outline-primary")"
                            @onclick="@(() => this.SetActiveFilter(ObjectTypeFilter.Others))">
                        @Resources.Others
                    </button>
                </div>
                <input class="small form-control"
                       type="search"
                       autofocus
                       @bind="@this._searchFilter"
                       @bind:event="oninput"
                       placeholder="@Resources.Search ..." />
            </div>
            <div class="map-object-select">
                <select title="Object"
                        id="objectSelect"
                        class="form-control"
                        size="@this.GetObjectListSize()"
                        @onchange="this.OnObjectSelectedAsync"
                        autocomplete="off"
                        disabled="@this._createMode"
                        @ref="_objectSelectRef">
                    <option value="@Guid.Empty" selected=@(this._focusedObject is null)>&lt;@Resources.NoSelection&gt;</option>
                    @foreach (var enterGate in this.SelectedMap.EnterGates.Where(g => MapObjectSelector.MatchesFilters(g, this._activeFilter, this._searchFilter)))
                    {
                        <option value="@enterGate.GetId()" selected=@(object.Equals(this._focusedObject, enterGate))>
                            @typeof(EnterGate).GetTypeCaption(): @enterGate.ToString()
                        </option>
                    }
                    @foreach (var exitGate in this.SelectedMap.ExitGates.Where(g => MapObjectSelector.MatchesFilters(g, this._activeFilter, this._searchFilter)))
                    {
                        <option value="@exitGate.GetId()" selected=@(object.Equals(this._focusedObject, exitGate))>
                            @typeof(ExitGate).GetTypeCaption(): @exitGate.ToString()
                        </option>
                    }
                    @foreach (var spawn in this.SelectedMap.MonsterSpawns.Where(s => MapObjectSelector.MatchesFilters(s, this._activeFilter, this._searchFilter)))
                    {
                        <option value="@spawn.GetId()" selected=@(object.Equals(this._focusedObject, spawn))>
                            @typeof(MonsterSpawnArea).GetTypeCaption(): @spawn.ToString()
                        </option>
                    }
                </select>
            </div>
        }
    </div>

    <div class="map-form-column">
        @if (this._focusedObject is not null)
        {
            <div class="map-object-form">
                @if (this._focusedObject is EnterGate enterGate)
                {
                    <AutoForm Model="@enterGate" OnValidSubmit="@this.OnValidSubmit" />
                }
                else if (this._focusedObject is ExitGate exitGate)
                {
                    <AutoForm Model="@exitGate" OnValidSubmit="@this.OnValidSubmit" />
                }
                else if (this._focusedObject is MonsterSpawnArea spawn)
                {
                    <AutoForm Model="@spawn" OnValidSubmit="@this.OnValidSubmit" />
                }
            </div>
        }
    </div>
</div>