@using MUnique.OpenMU.DataModel
@using MUnique.OpenMU.DataModel.Configuration
@using MUnique.OpenMU.Persistence
@using MUnique.OpenMU.Web.Shared.Properties
@using SixLabors.ImageSharp
@using SixLabors.ImageSharp.Formats.Png

@if (this._selectedMap is null)
{
    return;
}

<script>
      // plain javascript to make JS Interop easier

    function GetMapHostBoundingClientRect() {
      return document.getElementsByClassName("map-host")[0].getBoundingClientRect();
    }
</script>

<h3>@this.SelectedMap.Name</h3>

<div class="map-select">
    <label for="mapSelect">@Resources.SelectedMap:</label>
    <select title="Map" @onchange=this.OnMapSelectedAsync id="mapSelect" autocomplete="off">
        @foreach (var map in this.Maps ?? Enumerable.Empty<GameMapDefinition>())
        {
            <option value="@map.GetId()" selected=@(object.Equals(this.SelectedMap, map))>@Resources.Map: @map.ToString()</option>
        }
    </select>
</div>

<div class="btn-toolbar my-2" role="toolbar" aria-label="@Resources.Toolbar">
    <div class="btn-group mr-2" role="group" aria-label="@Resources.CreationGroup">
        <button type="button" class="btn btn-secondary" @onclick="@this.CreateNewSpawnArea" disabled="@this._createMode">
            <span class="oi oi-plus"></span> @typeof(MonsterSpawnArea).GetTypeCaption()
        </button>
        <button type="button" class="btn btn-secondary" @onclick="@this.CreateNewEnterGate" disabled="@this._createMode">
            <span class="oi oi-plus"></span> @typeof(EnterGate).GetTypeCaption()
        </button>
        <button type="button" class="btn btn-secondary" @onclick="@this.CreateNewExitGate" disabled="@this._createMode">
            <span class="oi oi-plus"></span> @typeof(ExitGate).GetTypeCaption()
        </button>
    </div>
    <div class="btn-group" role="group" aria-label="@Resources.ControlGroup">
        @if (this._createMode)
        {
            <button id="applyCreate" type="button" class="btn btn-primary" @onclick="@(_ => this._createMode = false)"><span class="oi oi-circle-check"></span></button>
            <button id="cancelCreate" type="button" class="btn btn-secondary" @onclick="@this.CancelCreationAsync"><span class="oi oi-circle-x"></span></button>
        }
        else if (this._focusedObject is not null)
        {
            <button id="duplicateFocused" type="button" class="btn btn-secondary" @onclick="@this.DuplicateFocusedObject"><span class="oi oi-copy"></span> @Resources.Duplicate</button>
            <button id="removeFocused" type="button" class="btn btn-secondary" @onclick="@this.RemoveFocusedObjectAsync"><span class="oi oi-x"></span> @Resources.Remove</button>
        }
    </div>
</div>

<div class="row flex-nowrap">
    <div class="map-column">
        @if (this._terrainImage is { })
        {
            <div class="map-host" width="@(_scale * 255)" height="@(_scale * 255)" @onmousemove="@this.OnMouseMoveAsync" @onmouseup="() => { _resizerPosition = null; _isDragging = false; }">
                <img src="@(this._terrainImage.ToBase64String(PngFormat.Instance))"
                     width="@(_scale * 255)"
                     height="@(_scale * 255)"
                     alt="@string.Format(Resources.TerrainOf, this.SelectedMap.Name)" />
                @foreach (var obj in this.GetMapObjects())
                {
                    <div class="@this.GetCssClass(obj)"
                         title="@obj.ToString()"
                         style="@this.GetSizeAndPositionStyle(obj)"
                         @onmousedown="@(args => this.OnStartDraggingAsync(args, obj))"
                         @onclick="@(_ => { if (!this._createMode) { this._focusedObject = obj; } })">
                        @if (this.ShowResizers(obj))
                        {
                            <Resizers Resizing="@this.OnStartResizing" />
                        }
                        else if (this.ShowArrow(obj, out var spawn))
                        {
                            <div class="arrow @this.GetFocusedRotation()"></div>
                        }
                        else
                        {
                            // show nothing
                        }
                    </div>
                }
            </div>
        }
    </div>

    <div class="col-4">
        @if (!this._createMode)
        {
            <div class="map-object-filter mb-2">
                <input class="small form-control" type="search" autofocus @bind="@_searchFilter" @bind:event="oninput" placeholder="@Resources.Search ..."/>
            </div>
            <div class="map-object-select">
                <select title="Object" id="objectSelect" class="form-control" size="@this.GetObjectListSize()" @onchange=this.OnObjectSelected autocomplete="off" disabled="@this._createMode">
                    <option value="@Guid.Empty" selected=@(this._focusedObject is null)>&lt;No selection&gt;</option>
                    @foreach (var enterGate in this.SelectedMap.EnterGates.Where(this.MatchesSearch))
                    {
                        <option value="@enterGate.GetId()" selected=@(object.Equals(this._focusedObject, enterGate))>@typeof(EnterGate).GetTypeCaption(): @enterGate.ToString()</option>
                    }
                    @foreach (var exitGate in this.SelectedMap.ExitGates.Where(this.MatchesSearch))
                    {
                        <option value="@exitGate.GetId()" selected=@(object.Equals(this._focusedObject, exitGate))>@typeof(ExitGate).GetTypeCaption(): @exitGate.ToString()</option>
                    }
                    @foreach (var spawn in this.SelectedMap.MonsterSpawns.Where(this.MatchesSearch))
                    {
                        <option value="@spawn.GetId()" selected=@(object.Equals(this._focusedObject, spawn))>@typeof(MonsterSpawnArea).GetTypeCaption(): @spawn.ToString()</option>
                    }
                </select>
            </div>
        }
    </div>

    <div class="col">
        @if (this._focusedObject != null)
        {
            <div class="map-object-form">
                @if (_focusedObject is EnterGate enterGate)
                {
                    <AutoForm Model="@enterGate" OnValidSubmit="@this.OnValidSubmit"></AutoForm>
                }
                else if (_focusedObject is ExitGate exitGate)
                {
                    <AutoForm Model="@exitGate" OnValidSubmit="@this.OnValidSubmit"></AutoForm>
                }
                else if (_focusedObject is MonsterSpawnArea spawn)
                {
                    <AutoForm Model="@spawn" OnValidSubmit="@this.OnValidSubmit"></AutoForm>
                }
            </div>
        }
    </div>
</div>