@using MUnique.OpenMU.GameLogic.PlugIns.InvasionEvents
@using MUnique.OpenMU.DataModel.Configuration
@using MUnique.OpenMU.Web.Shared.Services
@using MUnique.OpenMU.Web.Shared.Properties

@inherits Microsoft.AspNetCore.Components.Forms.InputBase<IList<InvasionSpawnConfiguration>>

<div class="card mb-3">
    <h5 class="card-header">
        <FieldLabel Text="@Label" ValueExpression="@this.ValueExpression" />
    </h5>
    <div class="card-body">
        @foreach (var spawn in this._viewModels)
        {
            <div class="border-bottom py-3 d-flex flex-column w-100">
                <div class="mb-3">
                    <LookupField TObject="MonsterDefinition"
                                 @bind-Value="spawn.Monster" />
                </div>
                <div class="mb-3">
                    <MultiLookupField TObject="GameMapDefinition"
                                      @bind-Value="spawn.Maps" />
                </div>
                <div class="d-flex align-items-center flex-wrap">
                    <div class="d-flex align-items-center me-4">
                        <label class="mb-0 me-2">@Resources.Quantity</label>
                        <InputNumber @bind-Value="spawn.Count"
                                     class="form-control"
                                     style="width: 70px;"
                                     min="1" max="254" />
                    </div>
                    <div class="d-flex align-items-center me-4">
                        <label class="mb-0 me-2">X</label>
                        <InputNumber @bind-Value="spawn.X"
                                     class="form-control"
                                     style="width: 70px;"
                                     min="0" max="255" />
                    </div>
                    <div class="d-flex align-items-center me-4">
                        <label class="mb-0 me-2">Y</label>
                        <InputNumber @bind-Value="spawn.Y"
                                     class="form-control"
                                     style="width: 70px;"
                                     min="0" max="255" />
                    </div>
                </div>
                <div class="mt-3 d-flex align-items-center">
                    <label class="mb-0" style="min-width: 250px;" for="@($"checkbox_{spawn.GetHashCode()}")">
                        @Resources.SpawnOnAllSelectedMaps
                        <details class="info-popup" @onclick:stopPropagation>
                            <summary></summary>
                            <div class="alert alert-secondary shadow me-3"><span class="oi oi-info" aria-hidden="true"></span> @Resources.SpawnOnAllSelectedMapsTooltip</div>
                        </details>
                    </label>
                    <input type="checkbox"
                           id="@($"checkbox_{spawn.GetHashCode()}")"
                           class="form-check-input mt-0"
                           @bind="spawn.IsSpawnOnAllMaps" />
                </div>
                <div class="mt-3 d-flex align-items-center">
                    <label class="mb-0" style="min-width: 250px;" for="@($"announce_checkbox_{spawn.GetHashCode()}")">
                        @Resources.AnnounceDeath
                        <details class="info-popup" @onclick:stopPropagation>
                            <summary></summary>
                            <div class="alert alert-secondary shadow me-3"><span class="oi oi-info" aria-hidden="true"></span> @Resources.AnnounceDeathTooltip</div>
                        </details>
                    </label>
                    <input type="checkbox"
                           id="@($"announce_checkbox_{spawn.GetHashCode()}")"
                           class="form-check-input mt-0"
                           @bind="spawn.AnnounceDeath" />
                </div>
                <div class="mt-3 text-end">
                    <button type="button"
                            class="btn btn-danger"
                            @onclick="@(() => this.OnRemoveClick(spawn))">
                        <span class="oi oi-trash" aria-hidden="true"></span> @Resources.Remove
                    </button>
                </div>
            </div>
        }
        <div class="mt-3">
            <button type="button" class="btn btn-primary" @onclick="@this.OnAddClick">
                <i class="oi oi-plus"></i> @Resources.AddValue
            </button>
        </div>
    </div>
</div>
