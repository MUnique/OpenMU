@typeparam TItem

@using MUnique.OpenMU.Web.Shared.Components.Modal

<EditForm Model="@this">
  <CascadingValue Value="@this.PersistenceContext">
    <LookupField TObject="TItem" @bind-Value="@Item" Label="@typeof(TItem).Name"/>
  </CascadingValue>

  <div class="form-actions">
    <button type="submit" @onclick="@SubmitAsync" class="btn btn-primary">OK</button>
    <button type="button" @onclick="@CancelAsync" class="btn btn-secondary">Cancel</button>
  </div>
</EditForm>
