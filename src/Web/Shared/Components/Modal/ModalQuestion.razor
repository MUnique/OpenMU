@using MUnique.OpenMU.Web.Shared.Components.Modal
@using MUnique.OpenMU.Web.Shared.Properties

<div>
  <p><span>@Question</span></p>
</div>

<div class="float-end" role="toolbar" aria-label="buttons">
  <div class="btn-group" role="group" aria-label="yes">
        <button type="button" class="btn btn-primary" @onclick="@(() => this.Modal.CloseAsync(ModalResult.Ok(true)))">@Resources.Yes</button>
  </div>
  <div class="btn-group" role="group" aria-label="no">
        <button type="button" class="btn btn-secondary" @onclick="@(() => this.Modal.CloseAsync(ModalResult.Ok(false)))">@Resources.No</button>
  </div>
</div>

@code {

    [Parameter]
    public ModalInstance Modal { get; set; } = null!;

    /// <summary>
    /// Gets or sets the text.
    /// </summary>
    [Parameter]
    public string Question { get; set; } = string.Empty;
}
